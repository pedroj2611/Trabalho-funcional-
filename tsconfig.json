{
  "compilerOptions": {
    "target": "ES6",
    "module": "ES6",
    "strict": true,
    "outDir": "./public/js",
    "rootDir": "./public/js",
    "sourceMap": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "lib": ["ES6", "DOM"]
  },
  "include": ["public/js/**/*.ts"],
  "exclude": ["node_modules"]
}
